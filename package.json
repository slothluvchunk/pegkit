{
  "name": "@slothluvchunkpegkit",
  "version": "0.1.0",
  "description": "A zero-dependency TypeScript Library for guess-and-feedback logic games",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "game",
    "wordle",
    "mastermind",
    "bulls-and-cows",
    "guess",
    "feedback",
    "typescript"
  ],
  "license": "MIT",
  "author": "Jonathan Finger <jonathan@tollidee.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/slothluvchunk/pegkit"
  },
  "bugs": {
    "url": "https://github.com/slothluvchunk/pegkit/issues"
  },
  "homepage": "https://github.com/slothluvchunk/pegkit#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
